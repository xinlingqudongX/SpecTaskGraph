{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": ["/public/**/*",{
        "include": "**/*.{yaml,yml}",
        "outDir": "dist"
    }]
  }
}